{
  "name": "git-repo-auth-mcp",
  "version": "0.1.0",
  "private": true,
  "description": "Worker-minted, short-lived, scoped GitHub App installation tokens over MCP. Currently GitHub; forge-agnostic by design.",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "node scripts/build-info.mjs && wrangler deploy",
    "typecheck": "tsc --noEmit",
    "build-info": "node scripts/build-info.mjs",
    "test": "vitest run",
    "test:smoke": "vitest run test/smoke.live.test.ts"
  },
  "dependencies": {
    "@cloudflare/workers-oauth-provider": "^0.7.2",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@octokit/auth-app": "^8.2.0",
    "agents": "^0.15.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260610.1",
    "@types/node": "^25.9.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8",
    "wrangler": "^4.99.0"
  }
}
